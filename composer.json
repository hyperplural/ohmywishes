{
  "name": "hyperplural/ohmywishes",
  "description": "SDK for the public Ohmywishes API",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.9",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.1",
    "psr/http-message": "^2.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^10.5",
    "rector/rector": "^1.2"
  },
  "autoload": {
    "psr-4": {
      "Hyperplural\\Ohmywishes\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Hyperplural\\Ohmywishes\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit",
    "cs:check": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php",
    "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
    "stan": "phpstan analyse --configuration=phpstan.neon",
    "rector:check": "rector process --dry-run --config=rector.php",
    "rector:fix": "rector process --config=rector.php"
  }
}
